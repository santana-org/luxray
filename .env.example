# 🤖 Luxray Discord Bot Configuration
# =====================================
# Copy this file to .env and fill in your values
# IMPORTANT: NEVER commit .env file to version control!

# 🔐 DISCORD API CREDENTIALS (Required)
# =====================================
# Your Discord bot token from https://discord.com/developers/applications
# Keep this secret and never share it!
DISCORD_TOKEN=your_bot_token_here

# Your application's Client ID from https://discord.com/developers/applications
# Found in the "General Information" section
CLIENT_ID=your_application_client_id_here

# 🎮 BOT BEHAVIOR (Optional)
# ===========================
# Guild ID for development (registers commands instantly instead of global)
# Leave commented out for global command registration
# GUILD_ID=your_guild_id_here

# Prefix for text-based commands (default: !)
# Examples: !, ?, >>, $
# BOT_PREFIX=!

# 📊 LOGGING (Optional)
# ====================
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# 🌍 ENVIRONMENT (Optional)
# =========================
# Environment type: development, staging, production (default: development)
# NODE_ENV=development

