{
	"name": "luxray",
	"version": "1.0.0",
	"description": "A minimal, clean, and scalable Discord bot built with TypeScript and discord.js",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc && tsc-alias",
		"start": "node dist/index.js",
		"dev": "nodemon --exec tsx src/index.ts",
		"dev:watch": "nodemon --exec tsx src/index.ts --watch src",
		"lint": "biome lint --write",
		"format": "biome format --write src",
		"check": "biome check --write"
	},
	"keywords": [
		"discord",
		"bot",
		"typescript"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"@prisma/adapter-better-sqlite3": "^7.7.0",
		"@santana-org/logger": "^0.2.0",
		"better-sqlite3": "^12.9.0",
		"discord.js": "^14.26.1",
		"dotenv": "^17.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@prisma/client": "^7.7.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"nodemon": "^3.1.14",
		"prisma": "^7.7.0",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
